{
  "compilerOptions": {
    "rootDir": ".",
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext", "dom", "dom.iterable"],
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@jeffusion/bungee-llms": ["packages/llms/src/index.ts"],
      "@jeffusion/bungee-llms/plugin-api": ["packages/llms/src/plugin-api.ts"]
    },
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["bun-types", "node", "bun", "jest"]
  }
}
