{
  "name": "@jeffusion/bungee-llms",
  "version": "4.0.0",
  "description": "Extensible LLM adapters and protocol conversion package for Bungee",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts src/plugin-api.ts --outdir dist --target bun && tsc -p tsconfig.build.json",
    "test": "echo 'No tests for llms package yet'",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@jeffusion/bungee-types": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "^1.3.2",
    "typescript": "^5.7.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openai": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openai-anthropic": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapter": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./registry": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./service": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin-api": {
      "types": "./dist/plugin-api.d.ts",
      "default": "./dist/plugin-api.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffusion/bungee",
    "directory": "packages/llms"
  },
  "license": "MIT"
}
