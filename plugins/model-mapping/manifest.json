{
  "name": "model-mapping",
  "version": "1.0.0",
  "builtin": true,
  "metadata": {
    "name": "metadata.name",
    "description": "plugin.description",
    "icon": "compare_arrows"
  },
  "configSchema": [
    {
      "name": "modelMappings",
      "type": "model_mapping",
      "label": "modelMapping.label",
      "description": "modelMapping.description",
      "placeholder": "modelMapping.placeholder",
      "catalogPlugin": "model-mapping"
    }
  ],
  "contributes": {
    "api": [
      {
        "path": "/models",
        "methods": ["GET"],
        "handler": "getModels"
      }
    ]
  },
  "translations": {
    "en": {
      "metadata.name": "Model Mapping",
