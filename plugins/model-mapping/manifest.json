      "modelMapping.placeholder": "Add source and target model mapping",
      "modelMapping.sourceLabel": "Source model",
      "modelMapping.targetLabel": "Target model",
      "modelMapping.sourceProviderFilter": "Source provider filter",
      "modelMapping.targetProviderFilter": "Target provider filter",
      "modelMapping.allProviders": "All providers",
      "modelMapping.addRow": "Add mapping",
      "modelMapping.empty": "No model mappings configured"
    },
    "zh-CN": {
      "metadata.name": "模型映射",
      "plugin.description": "独立的模型映射插件，在线拉取 Tokenlens 最新模型目录",
