{
  "name": "token-stats",
  "version": "2.0.0",
  "author": "Bungee Team",
  "schemaVersion": 2,
  "artifactKind": "runtime-plugin",
  "capabilities": ["hooks", "api", "nativeWidgetsStatic", "dynamicRuntimeLoad"],
  "uiExtensionMode": "native-static",
  "engines": {
    "bungee": "^3.2.0"
  },
  "main": "server/index.ts",
  "metadata": {
    "name": "metadata.name",
    "description": "plugin.description",
    "icon": "bar_chart"
  },
  "ui": {
    "components": [
      {
        "name": "TokenStatsChart",
        "entry": "ui/TokenStatsChart.svelte"
      }
    ]
  },
  "configSchema": [],
  "contributes": {
    "nativeWidgets": [
      {
        "id": "token-stats-chart",
        "title": "widgets.chart.title",
        "size": "medium",
        "component": "TokenStatsChart",
        "props": {}
      }
    ],
    "api": [
      {
        "path": "/stats",
        "methods": ["GET"],
        "handler": "getStats"
      }
    ]
  },
  "translations": {
    "en": {
      "metadata.name": "Token Statistics",
      "plugin.description": "Track AI API token usage by route, upstream, and provider",
      "widgets.chart.title": "Token Usage",
      "dimension.all": "All",
      "dimension.route": "By Route",
      "dimension.upstream": "By Upstream",
      "dimension.provider": "By Provider"
    },
    "zh-CN": {
      "metadata.name": "Token 统计",
      "plugin.description": "按路由、上游和提供商统计 AI API 的 Token 使用量",
      "widgets.chart.title": "Token 使用量",
      "dimension.all": "全部",
      "dimension.route": "按路由",
      "dimension.upstream": "按上游",
      "dimension.provider": "按提供商"
    }
  }
}
